rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Default Deny-All Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Helper Functions ---
    function isSignedIn() {
      return request.auth != null;
    }

    function isVerified() {
      return isSignedIn() && request.auth.token.email_verified == true;
    }

    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function isAdmin() {
      return isVerified() && getUserData().role == 'Admin';
    }

    function isManager() {
      return isVerified() && getUserData().role == 'Manager';
    }

    function getStore(storeId) {
      return get(/databases/$(database)/documents/stores/$(storeId)).data;
    }

    function hasStoreAccess(storeId) {
      let user = getUserData();
      return isAdmin() || (isVerified() && user.assignedStoreId == storeId);
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // --- Collection Rules ---

    // 1. User Profiles
    match /users/{userId} {
      allow get: if isVerified() && (request.auth.uid == userId || isAdmin());
      // Only Admins can list users or change roles
      allow list: if isAdmin();
      allow create: if isVerified() && request.auth.uid == userId && incoming().role == 'Staff'; // Default role
      allow update: if isVerified() && (
        (request.auth.uid == userId && incoming().diff(existing()).affectedKeys().hasOnly(['name'])) ||
        isAdmin()
      );
    }

    // 2. Stores
    match /stores/{storeId} {
      allow get: if isVerified() && hasStoreAccess(storeId);
      allow list: if isAdmin();
      allow create, update: if isAdmin();

      // --- Sub-collections for Stores ---

      // Products (Partitioned by Store)
      match /products/{productId} {
        allow get, list: if isVerified() && hasStoreAccess(storeId);
        allow write: if isVerified() && (isAdmin() || (isManager() && hasStoreAccess(storeId)));
      }

      // Stock Movements
      match /movements/{movementId} {
        allow get, list: if isVerified() && hasStoreAccess(storeId);
        allow create: if isVerified() && hasStoreAccess(storeId);
      }

      // Invoices
      match /invoices/{invoiceId} {
        allow get, list: if isVerified() && hasStoreAccess(storeId);
        allow create: if isVerified() && hasStoreAccess(storeId);
        allow update: if isVerified() && (isAdmin() || (isManager() && hasStoreAccess(storeId)));
      }
    }
  }
}
